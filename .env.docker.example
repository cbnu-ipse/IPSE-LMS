# ==========================================
# IPSE LMS — Docker 환경변수 템플릿
# 이 파일을 .env.docker 로 복사한 후 값을 채우세요.
# .env.docker 는 .gitignore에 등록되어 있습니다.
# ==========================================

# Django
SECRET_KEY=your-secret-key-here-change-this
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,cbnu-ipse.co.kr

# PostgreSQL
POSTGRES_DB=ipse_lms
POSTGRES_USER=ipse
POSTGRES_PASSWORD=change-this-strong-password
DATABASE_URL=postgresql://ipse:change-this-strong-password@db:5432/ipse_lms

# Email (운영 환경)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM_ADDRESS=noreply@cbnu-ipse.co.kr
EMAIL_TIMEOUT=30
PASSWORD_RESET_TIMEOUT=86400

# ==========================================
# Cloudflare Tunnel
# Zero Trust 대시보드 → Networks → Tunnels → 터널 생성 후 토큰 복사
# https://one.dash.cloudflare.com/
# ==========================================
TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
